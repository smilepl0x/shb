---
pagination:
  data: collections.topics
  size: 1
  alias: _topic
permalink: "{{ _topic.url }}/"
eleventyComputed:
  topic: "{{ _topic.name | downcase }}"
  stylesheet: "/css/topic{{ topic }}.css"
layout: main.liquid
---
<h5>{{_topic.name}} posts</h5>
<hr />
{% for post in collections.posts %}
  {% if post.data.topic == topic %}
    <a href="{{ post.url }}">{{ post.data.title }}</a>
  {% endif %}
{% endfor %}
